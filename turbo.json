{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"],
      "env": [
        "AI_GATEWAY_API_KEY",
        "AMA_CHAT_MODEL",
        "AMA_CHAT_PROVIDERS",
        "EDGE_CONFIG",
        "BLOB_BLOG_PREFIX",
        "BLOB_READ_WRITE_TOKEN",
        "BLOB_RESUME_PATH"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "coverage": {
      "outputs": ["coverage/**"]
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    }
  }
}
